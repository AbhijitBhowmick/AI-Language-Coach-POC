# ============================================================================
# Multi-Tenant Environment Configuration
# ============================================================================

# ============================================================================
# Database Configuration (Tenant 1: Language Coach)
# ============================================================================
DB_HOST=192.168.0.18
DB_PORT=5432
DB_NAME=language_coach
DB_USER=coach_user
DB_PASSWORD=Test@1234

# ============================================================================
# Database Configuration (Tenant 2: App2)
# ============================================================================
# Uncomment for tenant 2:
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=app2_db
# DB_USER=app2_user
# DB_PASSWORD=your_secure_app2_password

# ============================================================================
# JWT Configuration
# ============================================================================
JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-minimum-32-characters-long
JWT_EXPIRATION=86400000

# ============================================================================
# Authentik OIDC Configuration
# ============================================================================
AUTHENTIK_ISSUER_URI=http://localhost:9000/application/o
AUTHENTIK_CLIENT_ID=language-coach-client
AUTHENTIK_CLIENT_SECRET=your-authentik-client-secret
AUTHENTIK_JWK_SET_URI=http://localhost:9000/application/o/jwks

# ============================================================================
# Multi-Tenant Configuration
# ============================================================================
TENANT_ID=1
TENANT_NAME=language-coach
ALLOWED_TENANT_IDS=1,2

# ============================================================================
# Platform Configuration
# ============================================================================
PLATFORM_MODE=coach
INFRASTRUCTURE=local
APP_PORT=8080

# ============================================================================
# Gem

# ini API Key
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key

# ============================================================================
# Application Configuration
# ============================================================================
SPRING_PROFILES_ACTIVE=prod

# ============================================================================
# Authentik (for running Authentik via authentik-compose.yaml)
# ============================================================================
AUTHENTIK_SECRET_KEY=your-authentik-secret-key-min-32-chars
AUTHENTIK_TENANTS_API_KEY=your-tenant-api-key
DB_PASSWORD_AUTHENTIK=authentik_db_password
