# ============================================================================
# ai-universal-rag-engine-be Configuration
# ============================================================================

# ============================================================================
# Service Configuration
# ============================================================================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ============================================================================
# Qdrant Vector Database (Optimized for 1M users)
# ============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_COLLECTION=knowledge_vault
QDRANT_VECTOR_SIZE=1024
QDRANT_HNSW_M=16
QDRANT_HNSW_EF_CONSTRUCT=200
QDRANT_HNSW_EF=128
QDRANT_ON_DISK_PAYLOAD=true

# ============================================================================
# Valkey Cache (Redis-compatible)
# ============================================================================
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0
CACHE_TTL=3600

# ============================================================================
# Google Gemini AI
# ============================================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBEDDING_MODEL=text-embedding-004
GEMINI_GENERATION_MODEL=gemini-1.5-flash-002
GEMINI_PRO_MODEL=gemini-1.5-pro-002

# ============================================================================
# Security
# ============================================================================
JWT_SECRET=your-256-bit-secret-key-for-jwt-signing-minimum-32-characters-long
INTERNAL_API_KEY=your-internal-api-key-for-service-to-service-communication

# ============================================================================
# Chunking Configuration
# ============================================================================
CHUNK_SIZES={"document": 512, "web": 256, "social": 200, "audio": 400}
CHUNK_OVERLAP=50

# ============================================================================
# File Upload Limits
# ============================================================================
MAX_UPLOAD_DOC_SIZE=26214400
MAX_UPLOAD_AUDIO_SIZE=104857600

# ===============
=============================================================
# Embedding Configuration
# ============================================================================
EMBEDDER_TYPE=local
LOCAL_EMBEDDER_MODEL=mxbai-embed-large-v1

# ============================================================================
# Worker Configuration (High Concurrency)
# ============================================================================
WORKER_COUNT=4
WORKER_CONCURRENCY=100

# ============================================================================
# Development Mode
# ============================================================================
USE_MOCK=false
MOCK_EMBEDDING_DIM=1024
